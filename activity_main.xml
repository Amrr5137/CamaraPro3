<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- PREVIEW CÁMARA -->
    <com.example.miappcamarapro3.ui.CameraGLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextureView
        android:id="@+id/textureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 2. Controles manuales (encima del preview) -->
    <com.example.miappcamarapro3.ui.ManualControlsView
        android:id="@+id/manualControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="160dp"
        android:visibility="gone" />

    <!-- INFO OVERLAY (Subido un poco para no tapar controles) -->
    <TextView
        android:id="@+id/tvCameraInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="8dp"
        android:background="#66000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="ISO 100 1/125 AF"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:elevation="5dp" />

    <!-- PANEL DE FILTROS GPU -->
    <HorizontalScrollView
        android:id="@+id/filterButtonsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="80dp"
        android:background="#CC000000"
        android:elevation="8dp">
        <!-- ... (contenido igual) ... -->
        <LinearLayout
            android:id="@+id/filterButtonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">
            <Button android:id="@+id/btnFilterNormal" android:text="Normal" style="@style/GpuFilterButton"/>
            <Button android:id="@+id/btnFilterBW" android:text="B&amp;N" style="@style/GpuFilterButton"/>
            <Button android:id="@+id/btnFilterSepia" android:text="Sepia" style="@style/GpuFilterButton"/>
            <Button android:id="@+id/btnFilterNegative" android:text="Neg" style="@style/GpuFilterButton"/>
            <Button android:id="@+id/btnFilterIR" android:text="IR" style="@style/GpuFilterButton"/>
            <Button android:id="@+id/btnFilterNight" android:text="NVG" style="@style/GpuFilterButton"/>
            <Button android:id="@+id/btnFilterThermal" android:text="FLIR" style="@style/GpuFilterButton"/>
            <Button android:id="@+id/btnFilterSketch" android:text="Draw" style="@style/GpuFilterButton"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- BARRA INFERIOR: CAPTURA -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        android:elevation="8dp">
        <!-- ... (botones captura) ... -->
        <ImageButton android:id="@+id/btnGallery" android:layout_width="50dp" android:layout_height="50dp" android:src="@android:drawable/ic_menu_gallery" android:background="?attr/selectableItemBackgroundBorderless" android:scaleType="centerCrop"/>
        <ImageButton android:id="@+id/btnCapture" android:layout_width="70dp" android:layout_height="70dp" android:layout_marginHorizontal="40dp" android:src="@android:drawable/ic_menu_camera" android:background="@drawable/circle_button" android:scaleType="center"/>
        <ImageButton android:id="@+id/btnMultiCapture" android:layout_width="50dp" android:layout_height="50dp" android:src="@android:drawable/ic_menu_camera" android:background="?attr/selectableItemBackgroundBorderless" android:scaleType="centerCrop"/>
    </LinearLayout>

    <!-- PANEL DE EDICIÓN AVANZADA (Oculto por defecto) -->
    <LinearLayout
        android:id="@+id/advancedEditingPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE000000"
        android:orientation="vertical"
        android:visibility="gone"
        android:elevation="15dp">
        <!-- ... (contenido edición) ... -->
        <ImageView android:id="@+id/editingPreview" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/histogramView" android:layout_width="match_parent" android:layout_height="60dp" android:background="#222" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="8dp">
            <Button android:id="@+id/btnUndo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="↩" android:textSize="20sp" />
            <Button android:id="@+id/btnRedo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="↪" android:textSize="20sp" />
            <Button android:id="@+id/btnResetEdits" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Reset" />
            <Button android:id="@+id/btnApplyEdits" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Guardar" />
        </LinearLayout>
        <com.example.miappcamarapro3.ui.AdjustmentPanelView android:id="@+id/adjustmentPanel" android:layout_width="match_parent" android:layout_height="wrap_content" />
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#333">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="8dp">
                <Button android:id="@+id/btnDoubleExposure" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Doble Exp" android:textSize="11sp" />
                <Button android:id="@+id/btnLightLeaks" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="Light Leaks" android:textSize="11sp" />
                <Button android:id="@+id/btnAnalogFilm" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginStart="8dp" android:text="Película" android:textSize="11sp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- BARRA SUPERIOR: MODOS -->
    <HorizontalScrollView
        android:id="@+id/modeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:elevation="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnModeAuto"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="#2196F3"
                android:text="AUTO"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnModeManual"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#424242"
                android:text="MANUAL"
                android:textSize="12sp"
                android:elevation="21dp" />

            <Button
                android:id="@+id/btnModeRaw"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#424242"
                android:text="RAW"
                android:textSize="12sp"
                android:elevation="21dp" />

            <Button
                android:id="@+id/btnModeHdr"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#424242"
                android:text="HDR"
                android:textSize="12sp"
                android:elevation="21dp" />

            <Spinner
                android:id="@+id/cameraSelector"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#FFFFFF"
                android:elevation="21dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:elevation="30dp" />

</FrameLayout>