<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- PREVIEW CÁMARA -->
    <com.example.miappcamarapro3.ui.CameraGLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextureView
        android:id="@+id/textureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 2. Controles manuales (encima del preview) -->
    <com.example.miappcamarapro3.ui.ManualControlsView
        android:id="@+id/manualControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="160dp"
        android:visibility="gone" />

    <!-- INFO OVERLAY (Subido un poco para no tapar controles) -->
    <TextView
        android:id="@+id/tvCameraInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="8dp"
        android:background="#66000000"
        android:elevation="5dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="ISO 100 1/125 AF"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

    <!-- PANEL DE FILTROS GPU -->
    <HorizontalScrollView
        android:id="@+id/filterButtonsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="80dp"
        android:background="#CC000000"
        android:elevation="8dp">
        <!-- ... (contenido igual) ... -->
        <LinearLayout
            android:id="@+id/filterButtonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnFilterNormal"
                style="@style/GpuFilterButton"
                android:layout_height="48dp"
                android:text="Normal" />

            <Button
                android:id="@+id/btnFilterBW"
                style="@style/GpuFilterButton"
                android:text="B&amp;N" />

            <Button
                android:id="@+id/btnFilterSepia"
                style="@style/GpuFilterButton"
                android:text="Sepia" />

            <Button
                android:id="@+id/btnFilterNegative"
                style="@style/GpuFilterButton"
                android:text="Neg" />

            <Button
                android:id="@+id/btnFilterIR"
                style="@style/GpuFilterButton"
                android:text="IR" />

            <Button
                android:id="@+id/btnFilterNight"
                style="@style/GpuFilterButton"
                android:text="NVG" />

            <Button
                android:id="@+id/btnFilterThermal"
                style="@style/GpuFilterButton"
                android:text="FLIR" />

            <Button
                android:id="@+id/btnFilterSketch"
                style="@style/GpuFilterButton"
                android:text="Draw" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- BARRA INFERIOR: CAPTURA -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">
        <!-- ... (botones captura) ... -->
        <ImageButton
            android:id="@+id/btnGallery"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerCrop"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Galería"
            android:src="@android:drawable/ic_menu_gallery" />

        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="40dp"
            android:background="@drawable/circle_button"
            android:scaleType="center"
            android:src="@android:drawable/ic_menu_camera" />

        <ImageButton
            android:id="@+id/btnMultiCapture"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera" />
    </LinearLayout>

    <!-- PANEL DE EDICIÓN AVANZADA (Oculto por defecto) -->
    <LinearLayout
        android:id="@+id/advancedEditingPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE000000"
        android:elevation="15dp"
        android:orientation="vertical"
        android:visibility="gone">
        <!-- ... (contenido edición) ... -->
        <ImageView
            android:id="@+id/editingPreview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/histogramView"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#222" />

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnUndo"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↩"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnRedo"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↪"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnResetEdits"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset" />

            <Button
                android:id="@+id/btnApplyEdits"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Guardar" />
        </LinearLayout>

        <com.example.miappcamarapro3.ui.AdjustmentPanelView
            android:id="@+id/adjustmentPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#333">

            <LinearLayout
                style="?android:attr/buttonBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <Button
                    android:id="@+id/btnDoubleExposure"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Doble Exp"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btnLightLeaks"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="Light Leaks"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btnAnalogFilm"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="Película"
                    android:textSize="11sp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/topBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#AA000000"
        android:elevation="99dp"
        android:paddingTop="36dp"
        android:orientation="vertical">

        <!-- Fila 1: Utilidades -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFlash"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="#FFCC00"
                android:text="LUZ"
                android:textColor="#000000"
                android:textSize="10sp" />

            <Spinner
                android:id="@+id/cameraSelector"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:backgroundTint="#FFFFFF" />
        </LinearLayout>

        <!-- Fila 2: Modos Principales -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:orientation="horizontal">

                <Button android:id="@+id/btnModeAuto" android:layout_width="wrap_content" android:layout_height="40dp" android:text="AUTO" android:backgroundTint="#2196F3" android:textSize="11sp" />
                <Button android:id="@+id/btnModeManual" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginStart="4dp" android:text="MANUAL" android:backgroundTint="#424242" android:textSize="11sp" />
                <Button android:id="@+id/btnModeRaw" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginStart="4dp" android:text="RAW" android:backgroundTint="#424242" android:textSize="11sp" />
                <Button android:id="@+id/btnModeHdr" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginStart="4dp" android:text="HDR" android:backgroundTint="#424242" android:textSize="11sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Fila 3: Modos Especiales (Nuevos) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTimeLapse"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:backgroundTint="#9C27B0"
                android:text="TIME"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnAstro"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#1A237E"
                android:text="ASTRO"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnCollage"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#00695C"
                android:text="COLLAGE"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="30dp"
        android:visibility="gone" />

</FrameLayout>
